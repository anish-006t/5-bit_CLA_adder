* SPICE3 file created from inv.ext - technology: scmos

.include TSMC_180nm.txt
.param SUPPLY=1.8

.global gnd vdd


Vdd vdd 0 {SUPPLY}

Va in 0 PULSE(0 {SUPPLY} 8n 5p 5p 15n 30n)
.option scale=0.09u

M1000 out in VDD w_n7_n6# CMOSP w=20 l=2
+  ad=180 pd=58 as=180 ps=58
M1001 out in GND Gnd CMOSN w=10 l=2
+  ad=90 pd=38 as=90 ps=38
C0 out VDD 0.20fF
