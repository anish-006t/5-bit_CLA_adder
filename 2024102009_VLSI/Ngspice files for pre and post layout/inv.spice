C6 in w_n7_n6# 0.08fF
C7 GND Gnd 0.15fF
C8 out Gnd 0.09fF
C9 VDD Gnd 0.04fF
C10 in Gnd 0.22fF
C11 w_n7_n6# Gnd 1.49fF

.tran 0.1n 100n

.control

set hcopypscolor = 1 *White background for saving plots
set color0=white
set color1=black

run

plot V(in)+2 V(out)

.endc
.end



