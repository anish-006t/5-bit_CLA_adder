Vb b 0 PULSE(0 {SUPPLY} 8n 5p 5p 20n 40n)

.option scale=0.09u

M1000 a_bar a vdd w_93_n6# CMOSP w=20 l=2
+  ad=100 pd=50 as=100 ps=50
