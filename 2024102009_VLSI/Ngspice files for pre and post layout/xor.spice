+  ad=100 pd=60 as=50 ps=30
M1005 out b a_bar Gnd CMOSN w=10 l=2
+  ad=0 pd=0 as=0 ps=0
C0 vdd w_93_n6# 0.05fF
C1 w_123_1# a 0.32fF
C2 b a_bar 0.11fF
