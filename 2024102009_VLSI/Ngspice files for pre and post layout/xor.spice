C6 a_bar w_93_n6# 0.05fF
C7 out b 0.61fF
C8 a_bar a 0.30fF
C9 b a 0.04fF
C10 w_123_1# b 0.16fF
C11 vdd a_bar 0.21fF
C12 out a 0.46fF
